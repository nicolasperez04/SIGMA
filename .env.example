# =========================================
# SIGMA - Environment Variables Example
# Copiar este archivo a .env y llenar los valores
# NO COMMITEAR .env a Git
# =========================================

# ========== BASE DE DATOS ==========
DB_HOST=localhost
DB_PORT=3306
DB_NAME=SIGMABD
DB_USERNAME=root
DB_PASSWORD=root

# ========== JWT ==========
# Generar con: openssl rand -base64 32 (Linux/Mac)
# O con PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { [byte](Get-Random -Minimum 0 -Maximum 256) }))
# IMPORTANTE: Cada ambiente debe tener un secret DIFERENTE y SEGURO
JWT_SECRET=CHANGE_ME_GENERATE_NEW_256_BIT_BASE64_VALUE

# ========== EMAIL (SMTP) ==========
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=sigmausco@gmail.com
MAIL_PASSWORD=oepyskbbflxgawri

# ========== FILE STORAGE ==========
UPLOAD_DIR=./SIGMA-uploads/SIGMA-files

# ========== FRONTEND ==========
FRONTEND_URL=http://localhost:5173

# ========== SWAGGER/OPENAPI ==========
# true for development, false for production
SWAGGER_ENABLED=true

# ========== SPRING PROFILE ==========
# dev, test, staging, prod
SPRING_PROFILES_ACTIVE=dev


